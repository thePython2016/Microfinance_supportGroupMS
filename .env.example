# Local development (copy to .env). On Render, set these in the dashboard instead.

# Option A: single URL (recommended on Render)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Option B: separate variables (Supabase pooler example)
# DB_HOST=aws-0-eu-west-1.pooler.supabase.com
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres.your-project-ref
# DB_PASSWORD=your-password
# DB_SSLMODE=require
